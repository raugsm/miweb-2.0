{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadgsm.com/contracts/trust-safety-state.schema.json",
  "title": "AriadGSM Trust Safety State",
  "type": "object",
  "required": [
    "status",
    "engine",
    "version",
    "updatedAt",
    "policy",
    "contracts",
    "permissions",
    "riskMatrix",
    "approvalLedger",
    "inputArbiter",
    "permissionGate",
    "summary",
    "latestFindings",
    "safeNextActions",
    "limitedActions",
    "pausedActions",
    "requiresHumanActions",
    "blockedActions",
    "humanReport"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "attention", "blocked"] },
    "engine": { "type": "string" },
    "version": { "type": "string" },
    "updatedAt": { "type": "string" },
    "policy": {
      "type": "object",
      "required": ["version", "autonomyLevel", "decisions", "principles"],
      "properties": {
        "version": { "type": "string" },
        "autonomyLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
        "decisions": { "type": "array", "items": { "type": "string" } },
        "principles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "contracts": {
      "type": "object",
      "required": ["decisionSources", "inputArbiterState", "approvalEvent", "permissionState"],
      "properties": {
        "decisionSources": { "type": "array", "items": { "type": "string" } },
        "inputArbiterState": { "type": "string" },
        "approvalEvent": { "type": "string" },
        "permissionState": { "type": "string" }
      }
    },
    "permissions": { "type": "object" },
    "riskMatrix": { "type": "object" },
    "approvalLedger": {
      "type": "object",
      "required": ["approvalsRead", "approvalsApplied", "ttlSeconds", "applied"],
      "properties": {
        "approvalsRead": { "type": "integer", "minimum": 0 },
        "approvalsApplied": { "type": "integer", "minimum": 0 },
        "ttlSeconds": { "type": "integer", "minimum": 1 },
        "applied": { "type": "array", "items": { "type": "object" } }
      }
    },
    "inputArbiter": {
      "type": "object",
      "required": ["status", "phase", "decision", "activeOwner", "operatorHasPriority", "handsPausedOnly", "operatorIdleMs", "requiredIdleMs", "leaseId", "summary"],
      "properties": {
        "status": { "type": "string" },
        "phase": { "type": "string" },
        "decision": { "type": "string" },
        "activeOwner": { "type": "string" },
        "operatorHasPriority": { "type": "boolean" },
        "handsPausedOnly": { "type": "boolean" },
        "operatorIdleMs": { "type": "integer", "minimum": 0 },
        "requiredIdleMs": { "type": "integer", "minimum": 0 },
        "leaseId": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "permissionGate": {
      "type": "object",
      "required": ["decision", "reason", "canHandsRun", "allowedEngines"],
      "properties": {
        "decision": { "type": "string", "enum": ["ALLOW", "ALLOW_WITH_LIMIT", "ASK_HUMAN", "PAUSE_FOR_OPERATOR", "BLOCK"] },
        "reason": { "type": "string" },
        "canHandsRun": { "type": "boolean" },
        "allowedEngines": { "type": "object" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["decisionsRead", "actionsRead", "domainEventsRead", "approvalsRead", "approvalsApplied", "findings", "allowed", "allowedWithLimit", "paused", "blocked", "requiresHumanConfirmation", "critical", "safeNextActions", "irreversibleBlocked", "evidenceMissing"],
      "properties": {
        "decisionsRead": { "type": "integer", "minimum": 0 },
        "actionsRead": { "type": "integer", "minimum": 0 },
        "domainEventsRead": { "type": "integer", "minimum": 0 },
        "approvalsRead": { "type": "integer", "minimum": 0 },
        "approvalsApplied": { "type": "integer", "minimum": 0 },
        "findings": { "type": "integer", "minimum": 0 },
        "allowed": { "type": "integer", "minimum": 0 },
        "allowedWithLimit": { "type": "integer", "minimum": 0 },
        "paused": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "requiresHumanConfirmation": { "type": "integer", "minimum": 0 },
        "critical": { "type": "integer", "minimum": 0 },
        "safeNextActions": { "type": "integer", "minimum": 0 },
        "irreversibleBlocked": { "type": "integer", "minimum": 0 },
        "evidenceMissing": { "type": "integer", "minimum": 0 }
      }
    },
    "latestFindings": {
      "type": "array",
      "items": { "type": "object" }
    },
    "safeNextActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "limitedActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "pausedActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "requiresHumanActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "blockedActions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "humanReport": {
      "type": "object",
      "required": ["headline", "resumenDecision", "permitidas", "necesitanBryams", "bloqueadas", "riesgos"],
      "properties": {
        "headline": { "type": "string" },
        "resumenDecision": { "type": "string" },
        "permitidas": { "type": "array", "items": { "type": "string" } },
        "necesitanBryams": { "type": "array", "items": { "type": "string" } },
        "bloqueadas": { "type": "array", "items": { "type": "string" } },
        "riesgos": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
