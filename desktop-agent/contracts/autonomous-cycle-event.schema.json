{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadgsm.com/contracts/autonomous-cycle-event.schema.json",
  "title": "AriadGSM Autonomous Cycle Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "eventType",
    "cycleId",
    "createdAt",
    "status",
    "phase",
    "summary",
    "steps",
    "permissionGate",
    "stages"
  ],
  "properties": {
    "eventType": {
      "const": "autonomous_cycle_event"
    },
    "cycleId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "attention", "blocked"]
    },
    "phase": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "trigger": {
      "type": "string",
      "enum": ["start", "checkpoint", "recovery"]
    },
    "steps": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "required": ["stepId", "name", "status", "objective", "detail", "inputs", "outputs"],
        "additionalProperties": true,
        "properties": {
          "stepId": {
            "type": "string",
            "enum": ["observe", "understand", "plan", "request_permission", "act", "verify", "learn", "report"]
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["ok", "attention", "blocked"]
          },
          "objective": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "metrics": {
            "type": "object"
          },
          "gate": {
            "type": "object"
          }
        }
      }
    },
    "permissionGate": {
      "type": "object",
      "required": ["decision", "reason", "canHandsRun"],
      "additionalProperties": true,
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["ALLOW", "ALLOW_WITH_LIMIT", "ASK_HUMAN", "PAUSE_FOR_OPERATOR", "BLOCK"]
        },
        "reason": {
          "type": "string"
        },
        "canHandsRun": {
          "type": "boolean"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stageId", "name", "status", "detail"],
        "additionalProperties": true,
        "properties": {
          "stageId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["ok", "attention", "blocked"]
          },
          "detail": {
            "type": "string"
          },
          "metrics": {
            "type": "object"
          }
        }
      }
    },
    "directives": {
      "type": "object"
    },
    "humanReport": {
      "type": "object"
    }
  }
}
