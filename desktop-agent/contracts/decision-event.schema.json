{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AriadGSM Decision Event",
  "type": "object",
  "required": ["eventType", "decisionId", "createdAt", "goal", "intent", "confidence", "autonomyLevel", "proposedAction", "reasoningSummary"],
  "properties": {
    "eventType": { "const": "decision_event" },
    "decisionId": { "type": "string" },
    "createdAt": { "type": "string" },
    "goal": { "type": "string" },
    "intent": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "autonomyLevel": { "type": "integer", "minimum": 1, "maximum": 6 },
    "proposedAction": { "type": "string" },
    "requiresHumanConfirmation": { "type": "boolean" },
    "reasoningSummary": { "type": "string" },
    "evidence": { "type": "array" }
  }
}

