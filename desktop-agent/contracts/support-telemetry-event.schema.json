{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadgsm.com/contracts/support-telemetry-event.schema.json",
  "title": "AriadGSM Support Telemetry Event",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "eventType",
    "eventId",
    "createdAt",
    "traceId",
    "correlationId",
    "source",
    "severity",
    "category",
    "summary",
    "detail",
    "redaction",
    "evidence",
    "recommendedAction",
    "privacy"
  ],
  "properties": {
    "eventType": { "type": "string", "const": "support_telemetry_event" },
    "eventId": { "type": "string", "minLength": 8 },
    "createdAt": { "type": "string", "minLength": 1 },
    "traceId": { "type": "string", "minLength": 8 },
    "correlationId": { "type": "string", "minLength": 8 },
    "source": { "type": "string", "minLength": 1 },
    "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] },
    "category": {
      "type": "string",
      "enum": [
        "lifecycle",
        "runtime",
        "window_reality",
        "reader",
        "hands",
        "input",
        "updater",
        "cloud",
        "crash_hang",
        "privacy",
        "release"
      ]
    },
    "summary": { "type": "string" },
    "detail": { "type": "string" },
    "redaction": {
      "type": "object",
      "additionalProperties": true,
      "required": ["applied", "redactions"],
      "properties": {
        "applied": { "type": "boolean" },
        "redactions": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sourceFiles", "confidence", "visibleOnly"],
      "properties": {
        "sourceFiles": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "visibleOnly": { "type": "boolean" }
      }
    },
    "recommendedAction": { "type": "string" },
    "privacy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["cloudAllowed", "rawContentIncluded", "requiresConsent"],
      "properties": {
        "cloudAllowed": { "type": "boolean" },
        "rawContentIncluded": { "type": "boolean" },
        "requiresConsent": { "type": "boolean" }
      }
    }
  }
}
