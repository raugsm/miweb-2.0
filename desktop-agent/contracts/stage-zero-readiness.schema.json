{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AriadGSM Stage Zero Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "stageId",
    "createdAt",
    "version",
    "status",
    "summary",
    "checks",
    "humanReport",
    "nextStage"
  ],
  "properties": {
    "contractVersion": { "type": "string", "minLength": 1 },
    "stageId": { "type": "string", "const": "stage_zero_product_foundation" },
    "createdAt": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["ok", "attention", "blocked"] },
    "summary": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkId", "name", "status", "detail", "evidence"],
        "properties": {
          "checkId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["ok", "attention", "blocked"] },
          "detail": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "humanReport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queQuedoListo", "queFalta", "riesgos"],
      "properties": {
        "queQuedoListo": {
          "type": "array",
          "items": { "type": "string" }
        },
        "queFalta": {
          "type": "array",
          "items": { "type": "string" }
        },
        "riesgos": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "nextStage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stageNumber", "name", "status", "reason"],
      "properties": {
        "stageNumber": { "type": "integer", "minimum": 1 },
        "name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}

