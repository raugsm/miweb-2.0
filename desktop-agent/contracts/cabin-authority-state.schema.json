{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ariadgsm.com/contracts/cabin-authority-state.schema.json",
  "title": "AriadGSM Cabin Authority State",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "status",
    "engine",
    "contract",
    "authorityVersion",
    "phase",
    "summary",
    "reason",
    "updatedAt",
    "exclusiveWindowControl",
    "handsMayRecoverWindows",
    "handsMayArrangeWindows",
    "readiness",
    "launchPolicy",
    "policy",
    "channels",
    "blockers",
    "actions"
  ],
  "properties": {
    "status": { "type": "string", "enum": ["ok", "attention", "stopped"] },
    "engine": { "type": "string", "const": "ariadgsm_cabin_authority" },
    "contract": { "type": "string", "const": "cabin_authority_state" },
    "authorityVersion": { "type": "string", "minLength": 1 },
    "phase": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "exclusiveWindowControl": { "type": "boolean" },
    "handsMayFocus": { "type": "boolean" },
    "handsMayRecoverWindows": { "type": "boolean", "const": false },
    "handsMayArrangeWindows": { "type": "boolean", "const": false },
    "readiness": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "expectedChannels",
        "structuralReadyChannels",
        "actionReadyChannels",
        "coveredChannels",
        "missingChannels"
      ],
      "properties": {
        "expectedChannels": { "type": "integer", "minimum": 0 },
        "structuralReadyChannels": { "type": "integer", "minimum": 0 },
        "actionReadyChannels": { "type": "integer", "minimum": 0 },
        "coveredChannels": { "type": "integer", "minimum": 0 },
        "missingChannels": { "type": "integer", "minimum": 0 }
      }
    },
    "launchPolicy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "url",
        "profilePinningDefault",
        "shellUrlLaunchAllowed",
        "tabSelectionAllowedControlTypes"
      ],
      "properties": {
        "mode": { "type": "string", "const": "explicit_browser_executable_only" },
        "url": { "type": "string", "const": "https://web.whatsapp.com/" },
        "profilePinningDefault": { "type": "boolean", "const": false },
        "shellUrlLaunchAllowed": { "type": "boolean", "const": false },
        "tabSelectionAllowedControlTypes": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "policy": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 4
    },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "channelId",
          "browserProcess",
          "status",
          "structuralReady",
          "semanticFresh",
          "actionReady",
          "handsMayAct",
          "expectedBounds"
        ],
        "properties": {
          "channelId": { "type": "string", "minLength": 1 },
          "browserProcess": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": [
              "action_ready",
              "visible_ready",
              "ready",
              "covered",
              "missing",
              "human_required",
              "blocked",
              "stale"
            ]
          },
          "structuralReady": { "type": "boolean" },
          "semanticFresh": { "type": "boolean" },
          "actionReady": { "type": "boolean" },
          "handsMayAct": { "type": "boolean" },
          "remainingBlockers": { "type": "integer", "minimum": 0 },
          "expectedBounds": {
            "type": "object",
            "additionalProperties": true,
            "required": ["left", "top", "width", "height"],
            "properties": {
              "left": { "type": "integer" },
              "top": { "type": "integer" },
              "width": { "type": "integer", "minimum": 0 },
              "height": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["channelId", "code", "detail"],
        "properties": {
          "channelId": { "type": "string" },
          "code": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["channelId", "type", "detail"],
        "properties": {
          "channelId": { "type": "string" },
          "type": { "type": "string" },
          "detail": { "type": "string" }
        }
      }
    }
  }
}
