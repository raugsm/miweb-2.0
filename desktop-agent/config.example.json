{
  "runtimeDir": "./desktop-agent/runtime",
  "memoryDb": "./desktop-agent/runtime/agent-memory.sqlite",
  "stateFile": "./desktop-agent/runtime/core.state.json",
  "readerCore": {
    "observationsFile": "./scripts/visual-agent/runtime/reader-core/structured-observations.jsonl",
    "maxAgeSeconds": 45,
    "limit": 800
  },
  "operatingCore": {
    "conversationEventsFile": "./desktop-agent/runtime/conversation-events.jsonl",
    "decisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "accountingEventsFile": "./desktop-agent/runtime/accounting-events.jsonl",
    "stateFile": "./desktop-agent/runtime/operating-state.json",
    "db": "./desktop-agent/runtime/operating-core.sqlite",
    "limit": 200
  },
  "cognitiveCore": {
    "conversationEventsFile": "./desktop-agent/runtime/conversation-events.jsonl",
    "decisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "learningEventsFile": "./desktop-agent/runtime/learning-events.jsonl",
    "stateFile": "./desktop-agent/runtime/cognitive-state.json",
    "db": "./desktop-agent/runtime/cognitive-core.sqlite",
    "limit": 200
  },
  "memoryCore": {
    "conversationEventsFile": "./desktop-agent/runtime/conversation-events.jsonl",
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "learningEventsFile": "./desktop-agent/runtime/learning-events.jsonl",
    "accountingEventsFile": "./desktop-agent/runtime/accounting-events.jsonl",
    "stateFile": "./desktop-agent/runtime/memory-state.json",
    "db": "./desktop-agent/runtime/memory-core.sqlite",
    "limit": 500
  },
  "handsEngine": {
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "perceptionEventsFile": "./desktop-agent/runtime/perception-events.jsonl",
    "actionEventsFile": "./desktop-agent/runtime/action-events.jsonl",
    "stateFile": "./desktop-agent/runtime/hands-state.json",
    "autonomyLevel": 3,
    "executeActions": false,
    "allowTextInput": false,
    "allowSendMessage": false,
    "pollIntervalMs": 250,
    "maxCycles": 0,
    "decisionLimit": 200,
    "perceptionLimit": 50
  },
  "service": {
    "intervalSeconds": 0.75,
    "maxCycles": 0
  },
  "cloud": {
    "url": "https://ariadgsm.com",
    "enabled": false
  },
  "architecture": {
    "autonomyLevel": 1,
    "historyLimitDays": 30,
    "rawFramesUploadedToCloud": false,
    "visionStorageDir": "D:/AriadGSM/vision-buffer",
    "visionRetentionHours": 1,
    "visionMaxStorageGb": 40
  },
  "windowsBridge": {
    "mode": "pending-dotnet",
    "contract": "./desktop-agent/contracts/windows-bridge-event.schema.json"
  }
}
