{
  "runtimeDir": "./desktop-agent/runtime",
  "memoryDb": "./desktop-agent/runtime/agent-memory.sqlite",
  "stateFile": "./desktop-agent/runtime/core.state.json",
  "readerCore": {
    "observationsFile": "./scripts/visual-agent/runtime/reader-core/structured-observations.jsonl",
    "maxAgeSeconds": 45,
    "limit": 800
  },
  "operatingCore": {
    "conversationEventsFile": "./desktop-agent/runtime/timeline-events.jsonl",
    "decisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "accountingEventsFile": "./desktop-agent/runtime/accounting-events.jsonl",
    "stateFile": "./desktop-agent/runtime/operating-state.json",
    "db": "./desktop-agent/runtime/operating-core.sqlite",
    "limit": 200
  },
  "timelineCore": {
    "conversationEventsFile": "./desktop-agent/runtime/conversation-events.jsonl",
    "historyEventsFile": "./desktop-agent/runtime/history-conversation-events.jsonl",
    "timelineEventsFile": "./desktop-agent/runtime/timeline-events.jsonl",
    "stateFile": "./desktop-agent/runtime/timeline-state.json",
    "historyLimitDays": 30,
    "limit": 1000,
    "replaceOutput": true
  },
  "cognitiveCore": {
    "conversationEventsFile": "./desktop-agent/runtime/timeline-events.jsonl",
    "decisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "learningEventsFile": "./desktop-agent/runtime/learning-events.jsonl",
    "stateFile": "./desktop-agent/runtime/cognitive-state.json",
    "db": "./desktop-agent/runtime/cognitive-core.sqlite",
    "limit": 200
  },
  "memoryCore": {
    "conversationEventsFile": "./desktop-agent/runtime/timeline-events.jsonl",
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "learningEventsFile": "./desktop-agent/runtime/learning-events.jsonl",
    "accountingEventsFile": "./desktop-agent/runtime/accounting-events.jsonl",
    "domainEventsFile": "./desktop-agent/runtime/domain-events.jsonl",
    "stateFile": "./desktop-agent/runtime/memory-state.json",
    "db": "./desktop-agent/runtime/memory-core.sqlite",
    "limit": 500
  },
  "domainEventCore": {
    "visionEventsFile": "./desktop-agent/runtime/vision-events.jsonl",
    "perceptionEventsFile": "./desktop-agent/runtime/perception-events.jsonl",
    "conversationEventsFile": "./desktop-agent/runtime/timeline-events.jsonl",
    "rawConversationEventsFile": "./desktop-agent/runtime/conversation-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "accountingEventsFile": "./desktop-agent/runtime/accounting-events.jsonl",
    "learningEventsFile": "./desktop-agent/runtime/learning-events.jsonl",
    "actionEventsFile": "./desktop-agent/runtime/action-events.jsonl",
    "autonomousCycleEventsFile": "./desktop-agent/runtime/autonomous-cycle-events.jsonl",
    "humanFeedbackEventsFile": "./desktop-agent/runtime/human-feedback-events.jsonl",
    "domainEventsFile": "./desktop-agent/runtime/domain-events.jsonl",
    "stateFile": "./desktop-agent/runtime/domain-events-state.json",
    "db": "./desktop-agent/runtime/domain-events.sqlite",
    "limit": 500
  },
  "domainContractsCore": {
    "stateFile": "./desktop-agent/runtime/domain-contracts-final-state.json",
    "reportFile": "./desktop-agent/runtime/domain-contracts-final-report.json",
    "version": "0.8.2"
  },
  "autonomousCycleCore": {
    "stateFile": "./desktop-agent/runtime/autonomous-cycle-state.json",
    "eventsFile": "./desktop-agent/runtime/autonomous-cycle-events.jsonl",
    "directivesFile": "./desktop-agent/runtime/autonomous-cycle-directives.json",
    "reportFile": "./desktop-agent/runtime/autonomous-cycle-report.json",
    "trigger": "checkpoint",
    "limit": 250
  },
  "handsEngine": {
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "perceptionEventsFile": "./desktop-agent/runtime/perception-events.jsonl",
    "actionEventsFile": "./desktop-agent/runtime/action-events.jsonl",
    "stateFile": "./desktop-agent/runtime/hands-state.json",
    "autonomyLevel": 3,
    "executeActions": false,
    "allowTextInput": false,
    "allowSendMessage": false,
    "pollIntervalMs": 250,
    "maxCycles": 0,
    "decisionLimit": 200,
    "perceptionLimit": 50
  },
  "supervisorCore": {
    "cognitiveDecisionEventsFile": "./desktop-agent/runtime/cognitive-decision-events.jsonl",
    "operatingDecisionEventsFile": "./desktop-agent/runtime/decision-events.jsonl",
    "actionEventsFile": "./desktop-agent/runtime/action-events.jsonl",
    "stateFile": "./desktop-agent/runtime/supervisor-state.json",
    "autonomyLevel": 3,
    "limit": 200
  },
  "service": {
    "intervalSeconds": 0.75,
    "maxCycles": 0
  },
  "cloud": {
    "url": "https://ariadgsm.com",
    "enabled": false
  },
  "architecture": {
    "autonomyLevel": 1,
    "historyLimitDays": 30,
    "rawFramesUploadedToCloud": false,
    "visionStorageDir": "D:/AriadGSM/vision-buffer",
    "visionRetentionHours": 1,
    "visionMaxStorageGb": 40
  },
  "windowsBridge": {
    "mode": "pending-dotnet",
    "contract": "./desktop-agent/contracts/windows-bridge-event.schema.json"
  }
}
